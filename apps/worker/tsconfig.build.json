{
  "extends": "@hamafx/config/typescript/base",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // Inherit DOM types so the data-package imports (which use the
    // RequestInit { cache: 'no-store' } extension) typecheck cleanly.
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["test", "dist", "node_modules"]
}
