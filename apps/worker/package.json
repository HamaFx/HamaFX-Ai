{
  "name": "@hamafx/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "clean": "rm -rf node_modules .turbo dist"
  },
  "dependencies": {
    "@hamafx/ai": "workspace:*",
    "@hamafx/data": "workspace:*",
    "@hamafx/db": "workspace:*",
    "@hamafx/indicators": "workspace:*",
    "@hamafx/shared": "workspace:*",
    "@microsoft/signalr": "^8",
    "@sentry/node": "^10.54.0",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hamafx/config": "workspace:*",
    "@types/node": "^20.14.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
