{
  "name": "@hamafx/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "prebuild": "node scripts/set-build-id.mjs",
    "build": "pnpm run prebuild && next build && pnpm run postbuild",
    "postbuild": "node scripts/generate-sw.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "generate:icons": "node scripts/generate-icons.mjs",
    "clean": "rm -rf node_modules .turbo .next"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@hamafx/ai": "workspace:*",
    "@hamafx/data": "workspace:*",
    "@hamafx/db": "workspace:*",
    "@hamafx/indicators": "workspace:*",
    "@hamafx/shared": "workspace:*",
    "@sentry/nextjs": "^10.54.0",
    "@tanstack/react-query": "^5.62.7",
    "ai": "^5.0.0",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.0.4",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "^15.1.4",
    "next-view-transitions": "^0.3.5",
    "nuqs": "^2.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hamafx/config": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
