{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}", "tools/**/*.{mjs,ts}"],
      "project": ["scripts/**/*", "tools/**/*", "*.json", "*.mjs"]
    },
    "apps/web": {
      "entry": ["src/**/*.{ts,tsx}", "next.config.mjs"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/**/*.test.{ts,tsx}"]
    },
    "apps/worker": {
      "entry": ["src/**/*.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/ai": {
      "entry": ["src/**/*.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/data": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "entry": ["src/**/*.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "packages/indicators": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/config": {
      "entry": ["eslint/index.js"],
      "project": ["**/*.js"]
    },
    "packages/test-utils": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@ianvs/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ]
}
