#!/usr/bin/env bash
# .githooks/pre-commit — Scan staged changes for secrets before committing.
#
# Checks for common secret patterns:
#   - Sentry auth tokens (sntryu_)
#   - OpenAI API keys (sk-)
#   - Google API keys (AIza)
#   - Private key headers (BEGIN PRIVATE KEY)
#   - Generic bearer tokens / passwords in env files
#   - High-entropy strings in .env files
#
# Installation:
#   git config core.hooksPath .githooks
#
# Skip with:  git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Only scan if there are staged changes
if git diff --cached --quiet; then
  exit 0
fi

# Get list of staged files (new + modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# If no staged files, exit clean
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Patterns that indicate potential secrets
# Each pattern: regex to detect a potential secret
PATTERNS=(
  # Sentry auth tokens (starts with sntryu_)
  'sntryu_[a-zA-Z0-9]{20,}'
  # OpenAI / LLM API keys (sk- prefix)
  'sk-[a-zA-Z0-9]{20,}'
  # Generic API keys with obvious naming
  '[A-Z_]+_(API_KEY|SECRET|TOKEN|DSN)=["'"'"']?[A-Za-z0-9_\-]{20,}["'"'"']?'
  # Private key PEM headers
  'BEGIN (RSA |EC |OPENSSH |PGP )?PRIVATE KEY'
  # Vercel tokens
  'vercel_[a-zA-Z0-9]{20,}'
  # Supabase service role keys (sb_ prefix or eyJ JWT)
  'eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{20,}'
  # GitHub tokens
  'gh[pousr]_[a-zA-Z0-9]{20,}'
  # AWS keys
  'AKIA[0-9A-Z]{16}'
  # Google OAuth client secrets (GOCSPX- prefix)
  'GOCSPX-[a-zA-Z0-9_-]{20,}'
)

FOUND_SECRETS=false

# Check each staged file
while IFS= read -r file; do
  # Skip binary files, node_modules, .git, lock files
  case "$file" in
    *.lock|*.png|*.jpg|*.jpeg|*.gif|*.ico|*.woff*|*.ttf|*.eot|*.svg|*.map|*.d.ts|*-lock.json) continue ;;
    yarn.lock|pnpm-lock.yaml|package-lock.json) continue ;;
  esac

  # Skip if the file was deleted
  if [ ! -f "$file" ]; then
    continue
  fi

  # Only check the staged version
  # Note: `set -e` is active, so we use `|| continue` to handle binary files
  # that `git show` can't read as text.
  CONTENT=$(git show ":$file" 2>/dev/null) || continue
  if [ -z "$CONTENT" ]; then
    continue
  fi

  for pattern in "${PATTERNS[@]}"; do
    MATCHES=$(echo "$CONTENT" | grep -nE "$pattern" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
      # Determine if this file is likely intentionally storing secrets (like .env.example)
      if [[ "$file" == *.env* ]] && [[ "$file" != *".example"* ]]; then
        FOUND_SECRETS=true
        echo -e "${RED}✗ SECRET FOUND in $file (will be committed unless excluded)${NC}"
        echo -e "  Matched pattern: $pattern"
        while IFS= read -r line; do
          LINE_NUM=$(echo "$line" | cut -d: -f1)
          LINE_CONTENT=$(echo "$line" | cut -d: -f2-)
          # Redact the value for display (keep the key name)
          REDACTED=$(echo "$LINE_CONTENT" | sed -E 's/([=:]["'"'"']?)[^"'"'"' ]{4,}/\1[REDACTED]/g')
          echo -e "  ${YELLOW}Line $LINE_NUM:${NC} $REDACTED"
        done <<< "$MATCHES"
        echo ""
      fi
    fi
  done
done <<< "$STAGED_FILES"

if [ "$FOUND_SECRETS" = true ]; then
  echo -e "${RED}═══════════════════════════════════════════════════${NC}"
  echo -e "${RED}  COMMIT BLOCKED: Potential secrets found${NC}"
  echo -e "${RED}═══════════════════════════════════════════════════${NC}"
  echo ""
  echo "  If these are false positives (e.g., example/test values),"
  echo "  run: git commit --no-verify"
  echo ""
  echo "  If these are real secrets:"
  echo "    1. Unstage the file:    git reset HEAD <file>"
  echo "    2. Add to .gitignore"
  echo "    3. Rotate the exposed secret immediately"
  exit 1
fi

exit 0
