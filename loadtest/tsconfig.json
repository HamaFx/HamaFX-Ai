{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["k6"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["config/**/*.ts", "lib/**/*.ts", "scenarios/**/*.ts", "tests/**/*.ts", "types/**/*.d.ts"]
}
