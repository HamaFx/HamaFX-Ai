{
  "name": "hamafx-loadtest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r lib/data dist/lib/data/",
    "typecheck": "tsc --noEmit",
    "smoke": "k6 run tests/smoke-read-mix.ts",
    "smoke:market": "k6 run tests/smoke-market-read.ts",
    "smoke:write": "k6 run tests/smoke-write-mix.ts",
    "load": "k6 run tests/load-read-mix.ts",
    "load:market": "k6 run tests/load-market-read.ts",
    "load:write": "k6 run tests/load-write-mix.ts",
    "stress": "k6 run tests/stress-market-read.ts",
    "stress:write": "k6 run tests/stress-write-mix.ts",
    "smoke:config": "k6 run tests/smoke-config-mix.ts",
    "load:config": "k6 run tests/load-config-mix.ts",
    "spike": "k6 run tests/spike-read-mix.ts",
    "spike:write": "k6 run tests/spike-write-mix.ts",
    "soak": "k6 run tests/soak-read-mix.ts",
    "soak:write": "k6 run tests/soak-write-mix.ts",
    "seed": "node lib/seed/seed-users.mjs"
  },
  "devDependencies": {
    "@types/k6": "^0.57.0",
    "typescript": "^5.7.2"
  }
}
