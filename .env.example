# ==========================================================================
# HamaFX-Ai environment template.
# Copy to `.env.local` (Next.js auto-loads) and fill in. Never commit secrets.
#
# packages/shared/src/env.ts validates these at boot via zod. Apps fail fast
# on missing/invalid values.
#
# Generate random secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ==========================================================================


# --------------------------------------------------------------------------
# App
# --------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --------------------------------------------------------------------------
# Auth (NextAuth.js v5 — multi-user foundation)
#
#   NEXTAUTH_SECRET    REQUIRED. >=32 chars. Used to sign JWT session tokens.
#                      Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
#   NEXTAUTH_URL       REQUIRED. The canonical URL of your deployment (e.g. http://localhost:3000)
#   CRON_SECRET        Bearer token Vercel uses to invoke /api/cron/*. >=16.
#                      In production Vercel auto-provides this when crons
#                      are enabled — copy whatever value Vercel sets.
# --------------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-32-byte-hex-from-crypto-randomBytes
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=replace-with-16-byte-or-longer-secret

# --------------------------------------------------------------------------
# Encryption (BYOK — Bring Your Own Key)
#
#   ENCRYPTION_SECRET  REQUIRED for multi-user. 32-byte hex key used to
#                      encrypt user AI API keys at rest (AES-256-GCM).
#                      Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# --------------------------------------------------------------------------
ENCRYPTION_SECRET=replace-with-32-byte-hex


# --------------------------------------------------------------------------
# Database
#
#   DATABASE_URL  NOT REQUIRED for local dev — PGlite starts automatically.
#                 Set this only for Docker (docker compose up) or production
#                 (Supabase). Format: postgres://user:pass@host:5432/dbname
#
#   SUPABASE_URL        Optional — only if you use Supabase.
#   SUPABASE_SERVICE_ROLE_KEY  Optional — service-role key (server-only).
# --------------------------------------------------------------------------
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# --------------------------------------------------------------------------
# AI providers
#
# Personal-mode supports two transport modes — at least one must be set.
# When AI_GATEWAY_API_KEY is present it wins (gateway routes everything by
# prefixed model id). Otherwise we call Google directly via @ai-sdk/google.
#
#   AI_GATEWAY_API_KEY            Vercel AI Gateway. Lets you route to any
#                                 supported provider by prefixed id
#                                 (`openai/gpt-4.1`, `google/gemini-2.5-flash`).
#                                 Requires a card on file even for free credits.
#   GOOGLE_GENERATIVE_AI_API_KEY  Direct Google Gemini. Pair with a
#                                 `google/...` model id. Free tier covers
#                                 generous daily quota with no card.
#
# Per-deployment model ids:
#   AI_DEFAULT_MODEL     main chat model (when /settings/models
#                        hasn't picked an override; also the ultimate
#                        fallback if the resolver returns null)
#   AI_TITLE_MODEL       auto-title generator on first turn (also a
#                        planner-style cheap-tier fallback; may be
#                        overridden by the per-user picker in future)
#   AI_EMBEDDING_MODEL   used by RAG / memory embeddings only. Phase D2
#                        gives BYOK users a per-user picker in
#                        /settings/models → Advanced; this env var is
#                        the operator-set fallback for users who
#                        haven't picked one and have no embedding-
#                        capable provider configured.
# --------------------------------------------------------------------------
AI_GATEWAY_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
AI_DEFAULT_MODEL=google/gemini-2.5-flash
AI_TITLE_MODEL=google/gemini-2.5-flash-lite
AI_EMBEDDING_MODEL=openai/text-embedding-3-small


# --------------------------------------------------------------------------
# Vertex AI (BYOK for the AI Gateway, or direct via @ai-sdk/google-vertex)
#
# Configured via service account `vercel-vertex-ai@your-gcp-project-id.iam.gserviceaccount.com`
# with role `roles/aiplatform.user` on GCP project `your-gcp-project-id`.
#
#   GOOGLE_VERTEX_PROJECT                GCP project id.
#   GOOGLE_VERTEX_LOCATION               Region, e.g. us-central1.
#   GOOGLE_APPLICATION_CREDENTIALS_JSON  Full service-account key JSON
#                                        (single line). Server-only.
# --------------------------------------------------------------------------
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS_JSON=


# --------------------------------------------------------------------------
# Cache (OPTIONAL — personal-mode uses Next.js Data Cache for free)
#
# Phase 1a switched off the hard dependency on Upstash. The data adapters
# now cache via `fetch`'s built-in revalidation + `unstable_cache`, which
# Vercel persists across invocations at no cost. These vars are kept for
# a future swap-in (e.g. if we move to a worker that can't use Next's cache).
# --------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# --------------------------------------------------------------------------
# Data providers (server-only)
#
# Required for Phase 1+. Phase 0 boot will succeed without these.
#
#   FINNHUB_API_KEY        Fallback FX, secondary news, calendar.
#   ALPHAVANTAGE_API_KEY   Backup historical FX (deep history).
#   MARKETAUX_API_KEY      Primary financial news + sentiment.
#   TRADING_ECONOMICS_KEY  Primary economic calendar.
#   FRED_API_KEY           Macro time-series (CPI, NFP, ...).
#   BIQUOTE_BASE_URL       Optional override for the BiQuote endpoint.
#                          Defaults to https://biquote.io. No key required —
#                          BiQuote is unauthenticated for read endpoints
#                          (Phase 8 primary price/candle source).
#
# Note: `TWELVEDATA_API_KEY` was retired in Phase 8 PR-19 and removed
# from the schema in Phase 3 hardening §18. If your deployment still
# carries the variable, delete it from Vercel project envs the next
# time you rotate keys.
# --------------------------------------------------------------------------
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
MARKETAUX_API_KEY=
TRADING_ECONOMICS_KEY=
FRED_API_KEY=
# BIQUOTE_BASE_URL=https://biquote.io


# --------------------------------------------------------------------------
# Notifications (optional — Phase 1d / Phase 2 / F7+)
#
# Pick one channel for alert delivery. Email via Resend is simplest; Telegram
# is preferred for instant mobile pings.
#
#   TELEGRAM_BOT_TOKEN     Bot token from @BotFather.
#   TELEGRAM_CHAT_ID       Default chat ID for alert delivery (global).
#   TELEGRAM_SECRET_TOKEN  Secret token for webhook verification. Generated
#                          by the setup script (pnpm tsx scripts/setup-telegram-webhook.ts).
#                          Telegram sends this in the x-telegram-bot-api-secret-token header.
# --------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SECRET_TOKEN=

RESEND_API_KEY=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=


# --------------------------------------------------------------------------
# Web Push (Phase 3 — RFC 8030 + VAPID)
#
# Generate a fresh keypair with:
#
#   node -e "const {generateKeyPairSync} = require('crypto'); \
#     const {publicKey, privateKey} = generateKeyPairSync('ec', { namedCurve: 'P-256' }); \
#     const pubJwk = publicKey.export({format:'jwk'}); \
#     const privJwk = privateKey.export({format:'jwk'}); \
#     const pub = Buffer.concat([Buffer.from([4]), Buffer.from(pubJwk.x,'base64url'), Buffer.from(pubJwk.y,'base64url')]).toString('base64url'); \
#     console.log('VAPID_PUBLIC_KEY=' + pub); \
#     console.log('VAPID_PRIVATE_KEY=' + privJwk.d); \
#     console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY=' + pub);"
#
# `NEXT_PUBLIC_VAPID_PUBLIC_KEY` MUST equal `VAPID_PUBLIC_KEY` exactly — the
# browser uses it as `applicationServerKey` when subscribing.
# `VAPID_SUBJECT` is a contact URL embedded in the VAPID JWT; default is fine.
# --------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@hamafx.local
NEXT_PUBLIC_VAPID_PUBLIC_KEY=


# --------------------------------------------------------------------------
# TradingView Pro chart toggle (Phase 3)
#
# Set to "1" to render the "Pro" link on /chart/[symbol] and enable the
# `/chart/[symbol]/pro` route. Anything else hides the link and renders a
# disabled-state page on the Pro route.
# --------------------------------------------------------------------------
NEXT_PUBLIC_TRADINGVIEW_ENABLED=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# --------------------------------------------------------------------------
# Langfuse — LLM Observability (self-hosted, OpenTelemetry)
#
# Self-hosted at http://localhost:3001 (docker compose up).
# Create API keys in Langfuse UI → Settings → API Keys after first boot.
#
#   LANGFUSE_PUBLIC_KEY  pk-lf-... (public key, safe in client)
#   LANGFUSE_SECRET_KEY  sk-lf-... (secret key, server-only)
#   LANGFUSE_BASE_URL    http://localhost:3001 (self-hosted)
#                        or https://cloud.langfuse.com (cloud free tier)
#
# When any of these is unset, Langfuse tracing is silently disabled
# (no crash, no log spam — the OTel SDK just doesn't export).
# --------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001


# --------------------------------------------------------------------------
# Runtime guardrails
#
#   MAX_DAILY_USD       Daily AI spend ceiling. /api/chat returns 503 once
#                       crossed; resets at UTC midnight.
#   MAX_TOOL_ITERATIONS Hard cap on tool-loop iterations per chat turn.
#   LOG_PROMPTS         "1" to log full LLM prompts (debug only).
# --------------------------------------------------------------------------
MAX_DAILY_USD=5
MAX_TOOL_ITERATIONS=6
LOG_PROMPTS=0


# --------------------------------------------------------------------------
# Misc / Node
# --------------------------------------------------------------------------
NODE_ENV=development


# --------------------------------------------------------------------------
# Sentry (Phase 8 PR-18 — server-only)
#
# When unset, the instrumentation hook is a no-op. The web app NEVER pulls
# in the client SDK so the browser bundle stays clean. Both apps/web (Node
# routes) and apps/worker (the always-on consumer + heavy jobs) tag every
# event with { service, commit_sha } so a single DSN dashboards both.
# --------------------------------------------------------------------------
SENTRY_DSN=

# --------------------------------------------------------------------------
# F3 — Social Sentiment Integration (optional)
#
# When configured, the AI can fetch retail positioning and social sentiment
# data for forex/gold symbols. When unset, the sentiment service gracefully
# returns `available: false` and the Sentiment Agent degrades to news-only.
# --------------------------------------------------------------------------
SOCIAL_SENTIMENT_API_KEY=
SOCIAL_SENTIMENT_API_URL=
