{
  "name": "@hamafx/db",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./pglite": "./src/pglite-client.ts",
    "./local-db": "./src/local-db.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "clean": "rm -rf node_modules .turbo dist",
    "migrate:gen": "drizzle-kit generate",
    "migrate:gen:custom": "drizzle-kit generate --custom",
    "migrate:apply": "drizzle-kit migrate",
    "migrate:setup-extensions": "node scripts/install-extensions.mjs",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@hamafx/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@hamafx/config": "workspace:*",
    "@hamafx/test-utils": "workspace:*",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0"
}